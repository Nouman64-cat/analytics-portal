# Database
DATABASE_URL=postgresql://user:password@localhost:5432/rizviz-interviews-ai

# App
APP_NAME=RizViz Analytics Portal
APP_ENV=development
DEBUG=true

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Max upload body size in bytes (interview documents, resume PDFs). Default in app is 50MB if unset.
# Behind nginx, set e.g. client_max_body_size 50M; in the server block or requests may return 413 before FastAPI.
# MAX_UPLOAD_SIZE=52428800

# AWS: S3 uses AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY (or AWS_IAM_*). AWS_REGION applies to S3 and SES.
# Interview notification emails (SES SMTP). From address must be verified in Amazon SES.
# AWS_SES_FROM_EMAIL=noreply@your-verified-domain.com
# AWS_SES_USERNAME=
# AWS_SES_PASSWORD=

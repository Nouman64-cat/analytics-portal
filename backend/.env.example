# Database
DATABASE_URL=postgresql://user:password@localhost:5432/rizviz-interviews-ai

# App
APP_NAME=RizViz Analytics Portal
APP_ENV=development
DEBUG=true

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Max upload body size in bytes (interview documents, resume PDFs). Default in app is 50MB if unset.
# Behind nginx, set e.g. client_max_body_size 50M; in the server block or requests may return 413 before FastAPI.
# MAX_UPLOAD_SIZE=52428800

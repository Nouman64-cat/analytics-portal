# Database
DATABASE_URL=postgresql://user:password@localhost:5432/rizviz-interviews-ai

# JWT (required for API auth; generate a long random string in production)
# JWT_SECRET_KEY=

# ─── Database backups (superadmin: UI "Database backup" / POST /api/v1/admin/backup/) ───
# The pg_dump *client* major version must be >= the PostgreSQL *server* major version.
# If unset, the app runs `pg_dump` from PATH — verify with: pg_dump --version
#
# Ubuntu / Debian server (install client matching your server, e.g. PG 16):
#   sudo apt update && sudo apt install -y postgresql-client-16
#   which pg_dump && pg_dump --version
#   In production .env, set the full path (uncomment and adjust if needed):
# PG_DUMP_PATH=/usr/bin/pg_dump
#
# macOS Homebrew: postgresql@16 is "keg-only"; PATH may still use an older pg_dump unless you set:
#   Apple Silicon: PG_DUMP_PATH=/opt/homebrew/opt/postgresql@16/bin/pg_dump
#   Intel Mac:     PG_DUMP_PATH=/usr/local/opt/postgresql@16/bin/pg_dump
#
# systemd: if the service has a minimal PATH, set PG_DUMP_PATH to the full path from `which pg_dump`.
#
# Neon: managed schema `neon_auth` is not dumpable by the app user — exclude it (default):
# PG_DUMP_EXCLUDE_SCHEMAS=neon_auth
# Self-hosted DBs without neon_auth: set empty PG_DUMP_EXCLUDE_SCHEMAS= or omit (default still adds neon_auth; harmless).

# App
APP_NAME=RizViz Analytics Portal
APP_ENV=development
DEBUG=true

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Max upload body size in bytes (interview documents, resume PDFs). Default in app is 50MB if unset.
# Behind nginx, set e.g. client_max_body_size 50M; in the server block or requests may return 413 before FastAPI.
# MAX_UPLOAD_SIZE=52428800

# AWS: S3 uses AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY (or AWS_IAM_*). AWS_REGION applies to S3 and SES.
# AWS_S3_BUCKET_NAME=rizviz-interviews
# Interview notification emails (SES SMTP). From address must be verified in Amazon SES.
# AWS_SES_FROM_EMAIL=info@zygotrix.com
# AWS_SES_USERNAME=
# AWS_SES_PASSWORD=


CLIENT_URL=http://localhost:3000